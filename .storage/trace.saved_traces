                "to": "on",
                "for": "00:05:00",
                "trigger": "state"
              },
              {
                "entity_id": [
                  "binary_sensor.window_contact_sensors",
                  "binary_sensor.doors"
                ],
                "to": "off",
                "for": "00:00:30",
                "trigger": "state"
              }
            ],
            "conditions": [],
            "actions": [
              {
                "choose": [
                  {
                    "conditions": [
                      {
                        "condition": "or",
                        "conditions": [
                          {
                            "condition": "template",
                            "value_template": "{{ windows_open }}"
                          },
                          {
                            "condition": "template",
                            "value_template": "{{ doors_open }}"
                          }
                        ]
                      },
                      {
                        "condition": "state",
                        "entity_id": "input_boolean.hvac_pause_active",
                        "state": "off"
                      }
                    ],
                    "sequence": [
                      {
                        "data": {
                          "entity_id": "input_text.previous_hvac_mode_upstairs",
                          "value": "{{ states('climate.upstairs_thermostat') }}"
                        },
                        "action": "input_text.set_value"
                      },
                      {
                        "data": {
                          "entity_id": "input_number.previous_hvac_temp_upstairs",
                          "value": "{{ state_attr('climate.upstairs_thermostat', 'temperature') | float }}"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
