          "config": {
            "id": "1702994787994",
            "alias": "Notification or Lock Doors",
            "description": "",
            "triggers": [
              {
                "seconds": "/15",
                "trigger": "time_pattern"
              }
            ],
            "conditions": [],
            "actions": [
              {
                "alias": "Lock Basement after 30s at Night",
                "if": [
                  {
                    "alias": "Lock Closed Door after Sunset",
                    "condition": "and",
                    "conditions": [
                      {
                        "condition": "state",
                        "state": "unlocked",
                        "entity_id": "lock.basement_door_lock"
                      },
                      {
                        "condition": "state",
                        "state": "off",
                        "entity_id": "binary_sensor.basement_door_contact"
                      },
                      {
                        "condition": "sun",
                        "before": "sunrise",
                        "after": "sunset"
                      }
                    ]
                  }
                ],
                "then": [
                  {
                    "delay": {
                      "hours": 0,
                      "minutes": 0,
                      "seconds": 30,
                      "milliseconds": 0
                    }
                  },
                  {
                    "data": {
                      "code": "27514760"
                    },
                    "target": {
                      "entity_id": "lock.basement_door_lock"
                    },
                    "action": "lock.lock"
                  }
                ],
                "else": [
                  {
                    "alias": "Lock Basement after 3m during Day",
                    "if": [
                      {
                        "condition": "and",
                        "conditions": [
                          {
                            "condition": "state",
                            "state": "unlocked",
                            "entity_id": "lock.basement_door_lock"
                          },
