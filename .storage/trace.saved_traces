                "to": "on",
                "for": "00:03:00",
                "trigger": "state"
              },
              {
                "entity_id": "binary_sensor.doors",
                "to": "on",
                "for": "00:05:00",
                "trigger": "state"
              },
              {
                "entity_id": [
