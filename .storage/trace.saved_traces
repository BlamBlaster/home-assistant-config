                              }
                            ]
                          },
                          {
                            "conditions": [
                              {
                                "condition": "template",
                                "value_template": "{{ target_pct == 0 }}"
                              }
                            ],
                            "sequence": [
                              {
                                "target": {
                                  "entity_id": "fan.den_fan"
                                },
                                "action": "fan.turn_off",
                                "data": {}
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
