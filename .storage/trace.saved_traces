                            "after": "sunrise"
                          }
                        ]
                      }
                    ],
                    "then": [
                      {
                        "delay": {
                          "hours": 0,
                          "minutes": 3,
                          "seconds": 0,
                          "milliseconds": 0
                        }
                      },
                      {
                        "data": {
                          "code": "27514760"
                        },
                        "target": {
                          "entity_id": "lock.basement_door_lock"
                        },
                        "action": "lock.lock"
                      }
                    ],
                    "enabled": true,
                    "else": [
