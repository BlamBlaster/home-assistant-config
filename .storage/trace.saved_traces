          "config": {
            "id": "1746369230767",
            "alias": "HVAC Master Control",
            "triggers": [
              {
                "entity_id": "climate.upstairs_thermostat",
                "attribute": "hvac_action",
                "trigger": "state"
              },
              {
                "entity_id": "binary_sensor.window_contact_sensors",
                "to": "on",
                "for": "00:03:00",
                "trigger": "state"
              },
              {
                "entity_id": "binary_sensor.doors",
                "to": "on",
                "for": "00:05:00",
                "trigger": "state"
              },
              {
                "entity_id": [
                  "binary_sensor.window_contact_sensors",
                  "binary_sensor.doors"
                ],
                "to": "off",
                "for": "00:00:30",
                "trigger": "state"
              }
            ],
            "actions": [
              {
                "choose": [
                  {
                    "conditions": [
                      {
                        "condition": "or",
                        "conditions": [
                          {
                            "condition": "template",
                            "value_template": "{{ windows_open }}"
                          },
                          {
                            "condition": "template",
                            "value_template": "{{ doors_open }}"
                          }
                        ]
                      }
                    ],
                    "sequence": [
                      {
                        "data": {
                          "entity_id": "input_text.previous_hvac_mode_upstairs",
                          "value": "{{ upstairs_hvac_mode or 'off' }}"
                        },
                        "action": "input_text.set_value"
                      },
                      {
                        "data": {
                          "entity_id": "input_number.previous_hvac_temp_upstairs",
                          "value": "{{ upstairs_temp | float(72) }}"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "entity_id": "input_text.previous_hvac_mode_downstairs",
                          "value": "{{ downstairs_hvac_mode or 'off' }}"
                        },
                        "action": "input_text.set_value"
                      },
                      {
                        "data": {
                          "entity_id": "input_number.previous_hvac_temp_downstairs",
                          "value": "{{ downstairs_temp | float(72) }}"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "entity_id": "input_text.previous_upstairs_mode_select",
                          "value": "{{ states('select.upstairs_thermostat_current_mode') }}"
                        },
                        "action": "input_text.set_value"
                      },
                      {
                        "data": {
                          "entity_id": "input_text.previous_downstairs_mode_select",
                          "value": "{{ states('select.downstairs_current_mode_2') }}"
                        },
                        "action": "input_text.set_value"
                      },
                      {
                        "target": {
                          "entity_id": [
                            "climate.upstairs_thermostat",
                            "climate.downstairs_2"
                          ]
                        },
                        "data": {
                          "hvac_mode": "off"
                        },
                        "action": "climate.set_hvac_mode"
                      }
                    ]
                  },
                  {
                    "conditions": [
                      {
                        "condition": "template",
                        "value_template": "{{ not windows_open and not doors_open }}"
                      }
                    ],
                    "sequence": [
                      {
                        "target": {
                          "entity_id": "climate.upstairs_thermostat"
                        },
                        "data": {
                          "temperature": "{{ states('input_number.previous_hvac_temp_upstairs') | float(72) }}"
                        },
                        "action": "climate.set_temperature"
                      },
                      {
                        "target": {
                          "entity_id": "climate.upstairs_thermostat"
                        },
                        "data": {
                          "hvac_mode": "{{ states('input_text.previous_hvac_mode_upstairs') or 'off' }}"
                        },
                        "action": "climate.set_hvac_mode"
                      },
                      {
                        "target": {
                          "entity_id": "climate.downstairs_2"
                        },
                        "data": {
                          "temperature": "{{ states('input_number.previous_hvac_temp_downstairs') | float(72) }}"
                        },
                        "action": "climate.set_temperature"
                      },
                      {
                        "target": {
                          "entity_id": "climate.downstairs_2"
                        },
                        "data": {
                          "hvac_mode": "{{ states('input_text.previous_hvac_mode_downstairs') or 'off' }}"
                        },
                        "action": "climate.set_hvac_mode"
                      },
                      {
                        "choose": [
                          {
                            "conditions": [
                              {
                                "condition": "template",
                                "value_template": "{{ states('input_text.previous_upstairs_mode_select') in ['home', 'sleep', 'away'] }}"
                              }
                            ],
                            "sequence": [
                              {
                                "target": {
                                  "entity_id": "select.upstairs_thermostat_current_mode"
                                },
                                "data": {
                                  "option": "{{ states('input_text.previous_upstairs_mode_select') }}"
                                },
                                "action": "select.select_option"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "choose": [
                          {
                            "conditions": [
                              {
                                "condition": "template",
                                "value_template": "{{ states('input_text.previous_downstairs_mode_select') in ['home', 'sleep', 'away'] }}"
                              }
                            ],
                            "sequence": [
                              {
                                "target": {
                                  "entity_id": "select.downstairs_current_mode_2"
                                },
                                "data": {
                                  "option": "{{ states('input_text.previous_downstairs_mode_select') }}"
                                },
                                "action": "select.select_option"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "choose": [
                  {
                    "conditions": [
                      {
                        "condition": "template",
                        "value_template": "{{ is_state('binary_sensor.office_front_contact', 'on') or\n   is_state('binary_sensor.office_side_contact', 'on') }}"
                      }
                    ],
                    "sequence": [
                      {
                        "variables": {
                          "current_temp": "{{ states('sensor.office_multi_sensor_temperature') | float(72) }}",
                          "setpoint": "{{ states('input_number.previous_hvac_temp_upstairs') | float(72) }}",
                          "temp_diff": "{{ current_temp - setpoint }}",
                          "target_pct": "{% if temp_diff < -2 %} 0 {% elif temp_diff < 0 %} 16 {% elif temp_diff < 2 %} 33 {% elif temp_diff < 4 %} 50 {% elif temp_diff < 6 %} 75 {% else %} 100 {% endif %}"
                        }
                      },
                      {
                        "choose": [
                          {
                            "conditions": [
                              {
                                "condition": "template",
                                "value_template": "{{ target_pct > 0 }}"
                              }
                            ],
                            "sequence": [
                              {
                                "target": {
                                  "entity_id": "fan.office_fan"
                                },
                                "data": {
                                  "percentage": "{{ target_pct }}"
                                },
                                "action": "fan.set_percentage"
                              }
                            ]
                          },
                          {
                            "conditions": [
                              {
                                "condition": "template",
                                "value_template": "{{ target_pct == 0 }}"
                              }
                            ],
                            "sequence": [
                              {
                                "target": {
                                  "entity_id": "fan.office_fan"
                                },
                                "action": "fan.turn_off",
                                "data": {}
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
